{
  "name": "website",
  "version": "0.0.0",
  "description": "website",
  "main": "",
  "scripts": {
    "build": "node build_docs.js"
  },
  "author": {
    "name": "Suprema TW",
    "email": "TW@suprema.co.kr",
    "url": "https://github.com/supremainc"
  },
  "license": "MIT",
  "config": {},
  "bundleDependencies": [],
  "$devDependenciesUrls": [
    "https://www.npmjs.com/package/del-cli",
    "https://www.npmjs.com/package/open-cli",
    "https://www.npmjs.com/package/broken-link-checker"
  ],
  "devDependencies": {
    "broken-link-checker": "^0.7.8",
    "del-cli": "^5.0.0",
    "open-cli": "^7.2.0"
  },
  "xpack": {
    "minimumXpmRequired": "0.17.0",
    "actions": {
      "deep-clean": "del-cli node_modules html xml package-lock.json",
      "install": [
        "npm install",
        "xpm install"
      ],
      "link-deps": [
        "xpm link @micro-os-plus/build-helper"
      ],
      "doxygen": [
        "del-cli html",
        "doxygen biostar_device_sdk_en"
      ],
      "browser": "open-cli html/index.html",
      "check-urls": "blc https://micro-os-plus.github.io/utils-lists-xpack/ --recursive --ordered --filter-level 2"
    },
    "dependencies": {},
    "devDependencies": {
      "@jothepro/doxygen-awesome-css": "github:jothepro/doxygen-awesome-css",
      "@micro-os-plus/build-helper": "github:micro-os-plus/build-helper-xpack"
    },
    "properties": {},
    "buildConfigurations": {}
  }
}